{
  "version": 1,
  "app": {
    "bundleName": "com.opensource.harmony.offhand",
    "defaultSubtypeId": "zh-Hans-pinyin",
    "enableCloudFeaturesByDefault": false,
    "maxConcurrentSessions": 1
  },
  "input": {
    "candidatePageSize": 8,
    "maxCompositionLength": 64,
    "commitOnSpace": true,
    "enablePreviewText": false
  },
  "pinyin": {
    "engine": "librime",
    "enablePrediction": true,
    "enableMixedInput": true,
    "enableFuzzy": true,
    "fuzzyPairs": [
      ["z", "zh"],
      ["c", "ch"],
      ["s", "sh"],
      ["an", "ang"],
      ["en", "eng"],
      ["in", "ing"],
      ["l", "n"]
    ],
    "rime": {
      "schemaId": "offhand_pinyin",
      "sharedDataDir": "<app_private>/rime/shared",
      "userDataDir": "<app_private>/rime/user",
      "preloadSchemas": [
        "offhand_pinyin"
      ],
      "options": {
        "ascii_mode": false,
        "full_shape": false,
        "emoji_suggestion": true
      }
    }
  },
  "voice": {
    "enabled": true,
    "sampleRate": 16000,
    "maxRecordSeconds": 45,
    "requestTimeoutMs": 20000,
    "asrProvider": "auto",
    "asrEndpoint": "",
    "autoInsertResult": false,
    "autoPolishResult": true,
    "localAsr": {
      "enabled": true,
      "provider": "sherpa-onnx",
      "modelId": "sense-voice-zh-en-ja-ko-yue-2024-07-17-int8",
      "source": "sensevoice_local",
      "language": [
        "zh",
        "en",
        "ja",
        "ko",
        "yue"
      ],
      "captureSampleRate": 16000,
      "numThreads": 1,
      "lazyLoad": true,
      "releaseOnKeyboardHide": true,
      "partialEmitIntervalMs": 900,
      "decodingMethod": "greedy_search",
      "maxActivePaths": 4,
      "endpoint": {
        "enabled": true,
        "rule1MinTrailingSilence": 2.4,
        "rule2MinTrailingSilence": 1.8,
        "rule3MinUtteranceLength": 20
      }
    },
    "mockTranscript": "这是一次语音输入示例"
  },
  "llmPolish": {
    "enabled": true,
    "providerId": "moonshot",
    "providerName": "Moonshot",
    "modelPresetId": "kimi-default",
    "modelDisplayName": "Kimi K2.5",
    "apiModel": "kimi-k2.5",
    "protocol": "openai-compatible",
    "endpoint": "https://api.moonshot.cn/v1",
    "requestTimeoutMs": 12000,
    "autoPolishVoiceResult": true,
    "fallbackToLocalRewrite": true,
    "style": "clean_conversational"
  },
  "privacy": {
    "enablePersonalization": true
  }
}
