{
  /*
   * 说明：
   * 1. extensionAbilities[].type = "inputMethod" 已由当前 SDK schema 确认。
   * 2. metadata.name 在不同 API 版本上键名不完全一致，落地时以 SDK 头文件为准。
   *    候选优先级：ohos.extension.input_method > ohos_extension.input_method > input_method。
   * 3. 用户权限（如麦克风）在首次使用语音时通过 abilityAccessCtrl 动态申请。
   */
  "module": {
    "name": "entry",
    "type": "entry",
    "mainElement": "EntryAbility",
    "pages": "$profile:main_pages",
    "abilities": [
      {
        "name": "EntryAbility",
        "srcEntry": "./ets/entryability/EntryAbility.ets",
        "description": "$string:EntryAbility_desc",
        "icon": "$media:layered_image",
        "label": "$string:EntryAbility_label",
        "exported": true
      }
    ],
    "extensionAbilities": [
      {
        "name": "OffhandInputMethodExtAbility",
        "srcEntry": "./ets/ime/ability/OffhandInputMethodExtensionAbility.ets",
        "type": "inputMethod",
        "description": "$string:ime_desc",
        "icon": "$media:layered_image",
        "label": "$string:ime_name",
        "exported": true,
        "metadata": [
          {
            "name": "ohos.extension.input_method",
            "resource": "$profile:input_method_config"
          }
        ]
      },
      {
        "name": "EntryBackupAbility",
        "srcEntry": "./ets/entrybackupability/EntryBackupAbility.ets",
        "type": "backup",
        "exported": false,
        "metadata": [
          {
            "name": "ohos.extension.backup",
            "resource": "$profile:backup_config"
          }
        ]
      }
    ],
    "requestPermissions": [
      {
        "name": "ohos.permission.INTERNET",
        "reason": "$string:perm_reason_internet",
        "usedScene": {
          "abilities": ["OffhandInputMethodExtAbility"],
          "when": "always"
        }
      },
      {
        "name": "ohos.permission.GET_NETWORK_INFO",
        "reason": "$string:perm_reason_network_info",
        "usedScene": {
          "abilities": ["OffhandInputMethodExtAbility"],
          "when": "always"
        }
      },
      {
        "name": "ohos.permission.MICROPHONE",
        "reason": "$string:perm_reason_microphone",
        "usedScene": {
          "abilities": ["OffhandInputMethodExtAbility"],
          "when": "inuse"
        }
      },
      {
        "name": "ohos.permission.KEEP_BACKGROUND_RUNNING",
        "reason": "$string:perm_reason_keep_bg",
        "usedScene": {
          "abilities": ["OffhandInputMethodExtAbility"],
          "when": "inuse"
        }
      }
    ]
  }
}
